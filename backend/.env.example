# Restaurant OS - Backend Environment Variables Template
# Copy this to .env and fill in with your actual values

# ============================================================================
# APP CONFIGURATION
# ============================================================================
APP_NAME=Restaurant OS
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=development

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://localhost:3002", "http://localhost:3003"]

# ============================================================================
# DATABASE
# ============================================================================
# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://restaurant_user:restaurant_password@localhost:5432/restaurant_os
DB_ECHO=False

# ============================================================================
# SECURITY
# ============================================================================
SECRET_KEY=change-me-in-production-with-a-strong-secret-key-minimum-32-characters
JWT_SECRET=change-me-in-production-with-a-strong-jwt-secret-key-minimum-32-characters
ALGORITHM=HS256

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# REDIS
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# EMAIL (for notifications)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@restaurantos.com

# ============================================================================
# STRIPE PAYMENT GATEWAY
# ============================================================================
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================================================
# AWS S3 (for file uploads)
# ============================================================================
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET_NAME=restaurant-os-uploads
AWS_S3_REGION=us-east-1

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO

# ============================================================================
# AI/ML FEATURES
# ============================================================================
ENABLE_ML_FEATURES=True
OPENAI_API_KEY=sk-your-openai-key-here

# ============================================================================
# WEBSOCKET
# ============================================================================
WS_HEARTBEAT_INTERVAL=30

# ============================================================================
# FILE UPLOAD
# ============================================================================
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif

